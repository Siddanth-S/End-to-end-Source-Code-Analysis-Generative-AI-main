# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file with real API keys to GitHub!

# Google Generative AI API Key
# Get this from: https://aistudio.google.com/app/apikeys
GOOGLE_API_KEY=your-google-api-key-here

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Optional: Database Configuration (if using external DB)
# DATABASE_URL=

# Optional: AWS Configuration (if needed locally)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
